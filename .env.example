DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_test_guild_id

# Optional but required if you want Spotify URL support:
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=US
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8787/spotify/callback
SPOTIFY_OAUTH_SCOPES=playlist-read-private playlist-read-collaborative
SPOTIFY_USER_TOKEN_FILE=spotify-user-tokens.json

# Optional limits:
MAX_QUEUE_LENGTH=9999
MAX_SPOTIFY_TRACKS=9999
MAX_YOUTUBE_PLAYLIST_TRACKS=9999
SPOTIFY_SEARCH_CONCURRENCY=6
SPOTIFY_PROGRESS_EVERY=25
SPOTIFY_PROGRESS_MIN_INTERVAL_MS=2000
DEFAULT_VOLUME_PERCENT=80

# Optional playback normalization (recommended):
ENABLE_AUDIO_NORMALIZER=true
AUDIO_FILTER_CHAIN=dynaudnorm=f=250:g=13:m=15:s=10,alimiter=limit=0.95

UPCOMING_TRACK_LIMIT=10
